{
  "name": "@giulio-leone/lib-stores",
  "version": "0.1.0",
  "description": "Zustand stores per web e native",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth.store.d.ts",
      "import": "./dist/auth.store.js",
      "require": "./dist/auth.store.cjs"
    },
    "./onboarding": {
      "types": "./dist/onboarding.store.d.ts",
      "import": "./dist/onboarding.store.js",
      "require": "./dist/onboarding.store.cjs"
    },
    "./health.store": {
      "types": "./dist/health.store.d.ts",
      "import": "./dist/health.store.js",
      "require": "./dist/health.store.cjs"
    },
    "./iap.store": {
      "types": "./dist/iap.store.d.ts",
      "import": "./dist/iap.store.js",
      "require": "./dist/iap.store.cjs"
    },
    "./dialog.store": {
      "types": "./dist/dialog.store.d.ts",
      "import": "./dist/dialog.store.js",
      "require": "./dist/dialog.store.cjs"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "zustand": "^5.0.9"
  },
  "peerDependencies": {
    "@giulio-leone/constants": "^0.1.0",
    "@giulio-leone/lib-core": "^0.1.0",
    "@giulio-leone/lib-shared": "^0.1.0",
    "@giulio-leone/lib-theme": "^0.1.0",
    "@giulio-leone/types": "^0.2.0",
    "@prisma/client": "*"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "tsup": "^8.0.0"
  },
  "sideEffects": false
}

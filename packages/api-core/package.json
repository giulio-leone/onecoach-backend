{
  "name": "@giulio-leone/api-core",
  "version": "0.6.0",
  "description": "Unified API routes package — core, admin, analytics, chat, coach, exercise, food, nutrition, oneagenda, workout",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./food": {
      "types": "./src/food/index.ts",
      "default": "./src/food/index.ts"
    },
    "./nutrition": {
      "types": "./src/nutrition/index.ts",
      "default": "./src/nutrition/index.ts"
    },
    "./workout": {
      "types": "./src/workout/index.ts",
      "default": "./src/workout/index.ts"
    },
    "./admin": {
      "types": "./src/admin/index.ts",
      "default": "./src/admin/index.ts"
    },
    "./analytics": {
      "types": "./src/analytics/index.ts",
      "default": "./src/analytics/index.ts"
    },
    "./chat": {
      "types": "./src/chat/index.ts",
      "default": "./src/chat/index.ts"
    },
    "./coach": {
      "types": "./src/coach/index.ts",
      "default": "./src/coach/index.ts"
    },
    "./exercise": {
      "types": "./src/exercise/index.ts",
      "default": "./src/exercise/index.ts"
    },
    "./oneagenda": {
      "types": "./src/oneagenda/index.ts",
      "default": "./src/oneagenda/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@giulio-leone/constants": "workspace:*",
    "@giulio-leone/contracts": "workspace:*",
    "@giulio-leone/lib-api": "workspace:*",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-food": "workspace:*",
    "@giulio-leone/lib-marketplace": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/one-agent": "workspace:*",
    "@giulio-leone/one-nutrition": "workspace:*",
    "@giulio-leone/one-workout": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/types": "workspace:*",
    "next": ">=16.0.0",
    "next-auth": "5.0.0-beta.30",
    "@giulio-leone/lib-ai": "workspace:*",
    "@giulio-leone/lib-analytics": "workspace:*",
    "@giulio-leone/lib-chat-core": "workspace:*",
    "@giulio-leone/lib-coach": "workspace:*",
    "@giulio-leone/lib-exercise": "workspace:*",
    "@giulio-leone/lib-metadata": "workspace:*",
    "@giulio-leone/lib-vercel-admin": "workspace:*",
    "@giulio-leone/oneagenda-core": "workspace:*",
    "@giulio-leone/oneagenda-ui": "workspace:*",
    "@prisma/client": ">=5.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "sideEffects": false
}

{
  "name": "@giulio-leone/api-core",
  "version": "0.1.0",
  "description": "API routes per il dominio core (auth, profile, onboarding, payments, subscriptions, credits, invitations, policies, health, iap)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./food": {
      "types": "./src/food/index.ts",
      "default": "./src/food/index.ts"
    },
    "./nutrition": {
      "types": "./src/nutrition/index.ts",
      "default": "./src/nutrition/index.ts"
    },
    "./workout": {
      "types": "./src/workout/index.ts",
      "default": "./src/workout/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@giulio-leone/constants": "workspace:*",
    "@giulio-leone/contracts": "workspace:*",
    "@giulio-leone/lib-api": "workspace:*",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-food": "workspace:*",
    "@giulio-leone/lib-marketplace": "workspace:*",
    "@giulio-leone/lib-registry": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/one-agent": "workspace:*",
    "@giulio-leone/one-nutrition": "workspace:*",
    "@giulio-leone/one-workout": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/types": "workspace:*",
    "next": ">=16.0.0",
    "next-auth": "5.0.0-beta.30"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "sideEffects": false
}

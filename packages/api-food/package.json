  },
  "peerDependencies": {
    "@giulio-leone/contracts": "^0.1.0",
    "@giulio-leone/lib-api": "^0.1.0",
    "@giulio-leone/lib-core": "^0.1.0",
    "@giulio-leone/lib-food": "^0.1.0",
    "@giulio-leone/lib-registry": "^0.1.0",
    "@giulio-leone/one-agent": "^0.1.0",
    "@giulio-leone/schemas": "^0.1.0",
    "@giulio-leone/types": "^0.2.0"
  },
  "sideEffects": false
}

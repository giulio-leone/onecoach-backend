{
  "name": "@giulio-leone/lib-exercise",
  "version": "0.1.0",
  "description": "Servizi per il dominio esercizi",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@giulio-leone/lib-core": "^0.1.0",
    "@giulio-leone/lib-shared": "^0.1.0",
    "@giulio-leone/schemas": "^0.1.0",
    "@giulio-leone/types": "^0.2.0",
    "@giulio-leone/lib-metadata": "^0.1.0",
    "@giulio-leone/lib-api": "^0.1.0",
    "fast-json-patch": "^3.1.1"
  },
  "peerDependencies": {
    "@prisma/client": "^7.2.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "sideEffects": false
}

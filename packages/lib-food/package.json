{
  "name": "@giulio-leone/lib-food",
  "version": "0.10.0",
  "type": "module",
  "description": "Servizi per il dominio alimenti",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@giulio-leone/constants": "workspace:*",
    "@giulio-leone/lib-api": "workspace:*",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/types": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/client": ">=7.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "sideEffects": false
}

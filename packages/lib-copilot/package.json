{
  "name": "@giulio-leone/lib-copilot",
  "version": "0.2.0",
  "description": "Copilot context builders per AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./framework": {
      "types": "./src/framework/index.ts",
      "default": "./src/framework/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "ai": "6.0.77",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0"
  },
  "peerDependencies": {
    "@giulio-leone/lib-ai": "workspace:*",
    "@giulio-leone/lib-chat-core": "workspace:*",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-design-system": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/lib-stores": "workspace:*",
    "@giulio-leone/one-nutrition": "workspace:*",
    "@giulio-leone/one-workout": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/types": "workspace:*",
    "@prisma/client": "*",
    "zod": "^4.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}

{
  "name": "@giulio-leone/api-nutrition",
  "version": "0.1.0",
  "description": "API routes per il dominio nutrizione",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@giulio-leone/lib-registry": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/one-nutrition": "workspace:*"
  },
  "peerDependencies": {
    "next": "^16.0.0"
  },
  "sideEffects": false
}

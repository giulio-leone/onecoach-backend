{
  "name": "@giulio-leone/lib-metadata",
  "version": "0.2.0",
  "description": "Servizi metadata (translation, validation, catalog)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2"
  },
  "peerDependencies": {
    "@prisma/client": "^7.2.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "sideEffects": false
}

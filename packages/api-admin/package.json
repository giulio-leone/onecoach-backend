    "@giulio-leone/lib-food": "^0.1.0",
    "@giulio-leone/lib-marketplace": "^0.1.0",
    "@giulio-leone/lib-metadata": "^0.1.0",
    "@giulio-leone/lib-registry": "^0.1.0",
    "@giulio-leone/lib-vercel-admin": "^0.1.0",
    "@giulio-leone/schemas": "^0.1.0",
    "@giulio-leone/types": "^0.2.0",
    "@prisma/client": "*",
    "next": "*"

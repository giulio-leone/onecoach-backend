{
  "name": "@giulio-leone/api-admin",
  "version": "0.3.0",
  "description": "API routes per admin (users, feature-flags, policies, invitations, metadata, affiliates, promotions, config, etc.)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@giulio-leone/contracts": "workspace:*",
    "@giulio-leone/lib-ai": "workspace:*",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-exercise": "workspace:*",
    "@giulio-leone/lib-food": "workspace:*",
    "@giulio-leone/lib-marketplace": "workspace:*",
    "@giulio-leone/lib-metadata": "workspace:*",
    "@giulio-leone/lib-registry": "workspace:*",
    "@giulio-leone/lib-vercel-admin": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/types": "workspace:*",
    "@prisma/client": "*",
    "next": "*"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "sideEffects": false,
  "private": true
}

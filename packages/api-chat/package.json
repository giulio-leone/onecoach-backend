{
  "name": "@giulio-leone/api-chat",
  "version": "0.1.0",
  "description": "API routes per chat, conversations, copilot e agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./routes": {
      "types": "./dist/routes/index.d.ts",
      "import": "./dist/routes/index.js",
      "require": "./dist/routes/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@giulio-leone/types": "workspace:*",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/lib-chat-core": "workspace:*",
    "@giulio-leone/one-agent": "workspace:*",
    "@prisma/client": "^5.0.0",
    "next": "^16.0.0"
  },
  "sideEffects": false
}

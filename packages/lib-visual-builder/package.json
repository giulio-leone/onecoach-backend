{
  "name": "@giulio-leone/lib-visual-builder",
  "version": "0.6.0",
  "description": "Servizi per il dominio visual-builder",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js",
      "require": "./dist/hooks.cjs"
    },
    "./visual-builder.service": {
      "types": "./dist/visual-builder.service.d.ts",
      "import": "./dist/visual-builder.service.js",
      "require": "./dist/visual-builder.service.cjs"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "@prisma/client": "^7.2.0"
  },
  "peerDependencies": {
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/contracts": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/types": "workspace:*"
  },
  "sideEffects": false
}

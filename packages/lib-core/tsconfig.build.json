{
  "extends": "../../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noEmit": false,
    "incremental": false
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/auth/guards-client.*",
    "src/auth/auth-components.*",
    "src/user-memory/analyzer.*",
    "src/seeds/**/*",
    "src/db/init-db.ts",
    "src/subscription-init.ts",
    "src/services/**/*",
    "src/create-import-route.ts"
  ]
}

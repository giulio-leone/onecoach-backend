{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@giulio-leone/lib-shared": ["../lib-shared/src/index.ts"],
      "@giulio-leone/lib-shared/*": ["../lib-shared/src/*"],
      "@giulio-leone/lib-shared/id-generator": ["../lib-shared/src/id-generator.ts"],
      "@giulio-leone/types": ["../types/src/index.ts"],
      "@giulio-leone/types/*": ["../types/src/*"],
      "@giulio-leone/contracts": ["../contracts/src/index.ts"],
      "@giulio-leone/contracts/*": ["../contracts/src/*"],
      "@giulio-leone/constants": ["../constants/src/index.ts"],
      "@giulio-leone/constants/*": ["../constants/src/*"],
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/auth/guards-client.*",
    "src/auth/auth-components.*",
    "src/user-memory/analyzer.*",
    "src/seeds/**/*",
    "src/db/init-db.ts"
  ]
}

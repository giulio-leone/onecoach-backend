      ],
      "@giulio-leone/features/nutrition": [
        "./packages/app/src/features/nutrition/index.ts"
      ],
      "@giulio-leone/features/nutrition/*": [
        "./packages/app/src/features/nutrition/*"
      ],
      "@giulio-leone/features/nutrition/hooks": [
        "./packages/features/nutrition/hooks/index.ts"
      ],
      "@giulio-leone/features/workout": [
        "./packages/features/workout/index.ts"
      ],
      "@giulio-leone/features/workout/*": [
        "./packages/features/workout/*"
      ],
      "@giulio-leone/features/workout/hooks": [
        "./packages/features/workout/hooks/index.ts"
      ],
      "@giulio-leone/features/workouts": [
        "./packages/app/src/features/workouts/index.ts"
      ],
      "@giulio-leone/features/workouts/*": [
        "./packages/app/src/features/workouts/*"
      ],
      "@giulio-leone/features/calendar": [
        "./packages/app/src/features/calendar/index.ts"
      ],
      "@giulio-leone/features/calendar/*": [
        "./packages/app/src/features/calendar/*"
      ],
      "@giulio-leone/features/onboarding": [
        "./packages/app/src/features/onboarding/index.ts"
      ],
      "@giulio-leone/features/onboarding/*": [
        "./packages/app/src/features/onboarding/*"
      ],
      "@giulio-leone/features/chat": [
        "./packages/app/src/features/chat/index.ts"
      ],
      "@giulio-leone/features/chat/*": [
        "./packages/app/src/features/chat/*"
      ],
      "@giulio-leone/features/oneagenda": [

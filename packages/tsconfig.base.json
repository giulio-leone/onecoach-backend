{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "noPropertyAccessFromIndexSignature": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": "..",
    "paths": {
      "@giulio-leone/constants": [
        "../onecoach-constants/src/index.ts"
      ],
      "@giulio-leone/constants/*": [
        "../onecoach-constants/src/*"
      ],
      "@giulio-leone/schemas": [
        "../onecoach-schemas/src/index.ts"
      ],
      "@giulio-leone/schemas/*": [
        "../onecoach-schemas/src/*"
      ],
      "@giulio-leone/lib-core": [
        "./packages/lib-core/src/index.ts"
      ],
      "@giulio-leone/lib-core/*": [
        "./packages/lib-core/src/*"
      ],
      "@giulio-leone/lib-shared": [
        "../onecoach-shared/packages/lib-shared/src/index.ts"
      ],
      "@giulio-leone/lib-shared/*": [
        "../onecoach-shared/packages/lib-shared/src/*"
      ],
      "@giulio-leone/lib-shared/utils/*": [
        "../onecoach-shared/packages/lib-shared/src/utils/*"
      ],
      "@giulio-leone/lib-shared/utils/logger": [
        "../onecoach-shared/packages/lib-shared/src/utils/logger/index.ts"
      ],
      "@giulio-leone/lib-nutrition": [
        "../one-nutrition/src/index.ts"
      ],
      "@giulio-leone/lib-nutrition/*": [
        "../one-nutrition/src/*"
      ],
      "@giulio-leone/one-nutrition": [
        "../one-nutrition/src/index.ts"
      ],
      "@giulio-leone/one-nutrition/*": [
        "../one-nutrition/src/*"
      ],
      "@giulio-leone/one-nutrition/plan-transform": [
        "../one-nutrition/src/core/transformers/plan-transform.ts"
      ],
      "@giulio-leone/lib-nutrition/plan-sync": [
        "../one-nutrition/src/core/helpers/plan-sync.ts"
      ],
      "@giulio-leone/lib-nutrition/template-helpers": [
        "../one-nutrition/src/core/helpers/template-helpers.ts"
      ],
      "@giulio-leone/lib-workout": [
        "../one-workout/src/index.ts"
      ],
      "@giulio-leone/lib-workout/*": [
        "../one-workout/src/*"
      ],
      "@giulio-leone/one-workout": [
        "../one-workout/src/index.ts"
      ],
      "@giulio-leone/one-workout/*": [
        "../one-workout/src/*"
      ],
      "@giulio-leone/one-workout/program-transform": [
        "../one-workout/src/core/transformers/program-transform.ts"
      ],
      "@giulio-leone/one-workout/program-server-transform": [
        "../one-workout/src/core/transformers/program-server-transform.ts"
      ],
      "@giulio-leone/one-workout/normalizers/workout-normalizer": [
        "../one-workout/src/core/normalizers/workout-normalizer.ts"
      ],
      "@giulio-leone/one-workout/weight-calculator": [
        "../one-workout/src/core/calculators/weight-calculator.ts"
      ],
      "@giulio-leone/lib-workout/intensity-calculator": [
        "../one-workout/src/core/calculators/intensity-calculator.ts"
      ],
      "@giulio-leone/lib-workout/weight-calculator": [
        "../one-workout/src/core/workout-weight-calculator.service.ts"
      ],
      "@giulio-leone/lib-workout/program-transform": [
        "./packages/lib-workout/src/core/transformers/program-transform.ts"
      ],
      "@giulio-leone/lib-workout/utils/progression-calculator": [
        "./packages/lib-workout/src/core/calculators/progression-calculator.ts"
      ],
      "@giulio-leone/lib-workout/program-server-transform": [
        "./packages/lib-workout/src/core/transformers/program-server-transform.ts"
      ],
      "@giulio-leone/lib-workout/normalizers/workout-normalizer": [
        "./packages/lib-workout/src/core/normalizers/workout-normalizer.ts"
      ],
      "ai": [
        "./node_modules/ai/dist/index.d.ts"
      ],
      "ai/*": [
        "./node_modules/ai/dist/*"
      ],
      "@giulio-leone/lib-api": [
        "./packages/lib-api/src/index.ts"
      ],
      "@giulio-leone/lib-api/*": [
        "./packages/lib-api/src/*"
      ],
      "@giulio-leone/lib-ai": [
        "../lib-ai/src/index.ts"
      ],
      "@giulio-leone/lib-ai/*": [
        "../lib-ai/src/*"
      ],
      "@giulio-leone/lib-marketplace": [
        "./packages/lib-marketplace/src/index.ts"
      ],
      "@giulio-leone/lib-marketplace/*": [
        "./packages/lib-marketplace/src/*"
      ],
      "@giulio-leone/lib-api-client": [
        "./packages/lib-api-client/src/index.ts"
      ],
      "@giulio-leone/lib-api-client/*": [
        "./packages/lib-api-client/src/*"
      ],
      "@giulio-leone/lib-stores": [
        "./packages/lib-stores/src/index.ts"
      ],
      "@giulio-leone/lib-stores/*": [
        "./packages/lib-stores/src/*"
      ],
      "@giulio-leone/lib-design-system": [
        "../onecoach-ui/packages/lib-design-system/src/index.ts"
      ],
      "@giulio-leone/lib-design-system/*": [
        "../onecoach-ui/packages/lib-design-system/src/*"
      ],
      "design-system": [
        "../onecoach-ui/packages/design-system/src/index.ts"
      ],
      "design-system/*": [
        "../onecoach-ui/packages/design-system/src/*"
      ],
      "hooks": [
        "../onecoach-ui/packages/hooks/src/index.ts"
      ],
      "hooks/*": [
        "../onecoach-ui/packages/hooks/src/*"
      ],
      "ui": [

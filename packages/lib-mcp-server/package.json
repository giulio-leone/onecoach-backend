{
  "name": "@giulio-leone/lib-mcp-server",
  "version": "0.1.0",
  "description": "Centralized MCP Server for onecoach HTTP tools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.mjs",
      "require": "./dist/schemas/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "zod": "4.3.6",
    "zod-to-json-schema": "^3.25.1",
    "ai": "6.0.77"
  },
  "peerDependencies": {
    "@giulio-leone/lib-body-measurements": "^0.1.0",
    "@giulio-leone/lib-core": "^0.1.0",
    "@giulio-leone/lib-shared": "^0.1.0",
    "@giulio-leone/lib-exercise": "^0.1.0",
    "@giulio-leone/lib-food": "^0.1.0",
    "@giulio-leone/one-nutrition": "^0.1.0",
    "@giulio-leone/one-workout": "^0.1.0",
    "@giulio-leone/lib-import-core": "^0.1.0",
    "@giulio-leone/constants": "^0.1.0",
    "@giulio-leone/lib-metadata": "^0.1.0",
    "@giulio-leone/schemas": "^0.1.0",
    "@giulio-leone/types": "^0.2.0",
    "@prisma/client": "^7.2.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "tsup": "^4.0.0"
  }
}

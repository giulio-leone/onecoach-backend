{
  "name": "@giulio-leone/lib-api-client",
  "version": "0.1.0",
  "description": "API client (core, hooks, queries, react-query) per web e native",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.mjs",
      "require": "./dist/hooks/*.js"
    },
    "./react-query": {
      "types": "./dist/react-query/index.d.ts",
      "import": "./dist/react-query/index.mjs",
      "require": "./dist/react-query/index.js"
    },
    "./react-query/*": {
      "types": "./dist/react-query/*.d.ts",
      "import": "./dist/react-query/*.mjs",
      "require": "./dist/react-query/*.js"
    },
    "./queries": {
      "types": "./dist/queries/index.d.ts",
      "import": "./dist/queries/index.mjs",
      "require": "./dist/queries/index.js"
    },
    "./queries/*": {
      "types": "./dist/queries/*.d.ts",
      "import": "./dist/queries/*.mjs",
      "require": "./dist/queries/*.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "import": "./dist/memory.mjs",
      "require": "./dist/memory.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.mjs",
      "require": "./dist/native.js"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.20"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-marketplace": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/lib-stores": "workspace:*",
    "@giulio-leone/types": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@giulio-leone/lib-core": {
      "optional": false
    },
    "@giulio-leone/lib-marketplace": {
      "optional": false
    },
    "@giulio-leone/lib-shared": {
      "optional": false
    },
    "@giulio-leone/lib-stores": {
      "optional": false
    },
    "@giulio-leone/types": {
      "optional": false
    }
  },
  "sideEffects": false
}

{
  "name": "@giulio-leone/api-exercise",
  "version": "0.2.0",
  "description": "API routes per il dominio esercizi",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@giulio-leone/contracts": "workspace:*",
    "@giulio-leone/lib-api": "workspace:*",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-exercise": "workspace:*",
    "@giulio-leone/lib-registry": "workspace:*",
    "@giulio-leone/one-agent": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/lib-metadata": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/one-workout": "workspace:*",
    "@giulio-leone/types": "workspace:*",
    "@prisma/client": "^5.0.0",
    "next": "^16.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "sideEffects": false
}

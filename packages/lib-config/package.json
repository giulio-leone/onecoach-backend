{
  "name": "@giulio-leone/lib-config",
  "version": "0.1.0",
  "description": "Environment variables e configurazione",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./env.server": {
      "import": {
        "types": "./dist/env.server.d.ts",
        "default": "./dist/env.server.js"
      },
      "require": {
        "types": "./dist/env.server.d.cts",
        "default": "./dist/env.server.cjs"
      }
    },
    "./env": {
      "import": {
        "types": "./dist/env.d.ts",
        "default": "./dist/env.js"
      },
      "require": {
        "types": "./dist/env.d.cts",
        "default": "./dist/env.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "server-only": "*"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "sideEffects": false
}
{
  "name": "@giulio-leone/lib-api",
  "version": "0.10.0",
  "description": "API client e hooks per React Query",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./react-query": {
      "types": "./dist/react-query/index.d.ts",
      "import": "./dist/react-query/index.mjs",
      "require": "./dist/react-query/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.mjs",
      "require": "./dist/hooks/*.js"
    },
    "./habits": {
      "types": "./dist/habits.d.ts",
      "import": "./dist/habits.mjs",
      "require": "./dist/habits.js"
    },
    "./error-handler": {
      "types": "./dist/error-handler.d.ts",
      "import": "./dist/error-handler.mjs",
      "require": "./dist/error-handler.js"
    },
    "./error-handler.native": {
      "types": "./dist/error-handler.native.d.ts",
      "import": "./dist/error-handler.native.mjs",
      "require": "./dist/error-handler.native.js"
    },
    "./error-handler/core": {
      "types": "./dist/error-handler/core.d.ts",
      "import": "./dist/error-handler/core.mjs",
      "require": "./dist/error-handler/core.js"
    },
    "./projects": {
      "types": "./dist/projects.d.ts",
      "import": "./dist/projects.mjs",
      "require": "./dist/projects.js"
    },
    "./queries/exercise.queries": {
      "types": "./dist/queries/exercise.queries.d.ts",
      "import": "./dist/queries/exercise.queries.mjs",
      "require": "./dist/queries/exercise.queries.js"
    },
    "./utils/generation-handler": {
      "types": "./dist/utils/generation-handler.d.ts",
      "import": "./dist/utils/generation-handler.mjs",
      "require": "./dist/utils/generation-handler.js"
    },
    "./utils/streaming-handler": {
      "types": "./dist/utils/streaming-handler.d.ts",
      "import": "./dist/utils/streaming-handler.mjs",
      "require": "./dist/utils/streaming-handler.js"
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "@giulio-leone/constants": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/lib-stores": "workspace:*",
    "@tanstack/react-query": "^5.90.20"
  },
  "peerDependencies": {
    "@giulio-leone/types": "workspace:*",
    "@prisma/client": "*",
    "react": ">=19.1.0 <20",
    "react-native": ">=0.81 <0.83",
    "next": "*",
    "next-auth": "*"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "next-auth": {
      "optional": true
    }
  },
  "sideEffects": false
}

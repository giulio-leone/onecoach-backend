{
  "name": "@giulio-leone/lib-marketplace",
  "version": "0.1.0",
  "description": "Servizi marketplace (marketplace, coach, affiliate, promotion)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./affiliate.service": {
      "types": "./dist/affiliate.service.d.ts",
      "import": "./dist/affiliate.service.mjs",
      "require": "./dist/affiliate.service.js"
    },
    "./promotion.service": {
      "types": "./dist/promotion.service.d.ts",
      "import": "./dist/promotion.service.mjs",
      "require": "./dist/promotion.service.js"
    },
    "./marketplace.service": {
      "types": "./dist/marketplace.service.d.ts",
      "import": "./dist/marketplace.service.mjs",
      "require": "./dist/marketplace.service.js"
    },
    "./affiliate-logger.service": {
      "types": "./dist/affiliate-logger.service.d.ts",
      "import": "./dist/affiliate-logger.service.mjs",
      "require": "./dist/affiliate-logger.service.js"
    },
    "./payout-audit.service": {
      "types": "./dist/payout-audit.service.d.ts",
      "import": "./dist/payout-audit.service.mjs",
      "require": "./dist/payout-audit.service.js"
    },
    "./payout-profile.service": {
      "types": "./dist/payout-profile.service.d.ts",
      "import": "./dist/payout-profile.service.mjs",
      "require": "./dist/payout-profile.service.js"
    },
    "./cart.service": {
      "types": "./dist/cart.service.d.ts",
      "import": "./dist/cart.service.mjs",
      "require": "./dist/cart.service.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "@giulio-leone/constants": "workspace:*",
    "@giulio-leone/contracts": "workspace:*",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-shared": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "stripe": "^17.0.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@giulio-leone/types": "workspace:*",
    "@prisma/client": "^7.2.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}

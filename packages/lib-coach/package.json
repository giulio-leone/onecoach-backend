{
  "name": "@giulio-leone/lib-coach",
  "version": "0.8.0",
  "description": "Servizi per il dominio coach",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./coach.service": {
      "types": "./dist/coach.service.d.ts",
      "import": "./dist/coach.service.js",
      "require": "./dist/coach.service.cjs"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "@prisma/client": "^7.2.0"
  },
  "peerDependencies": {
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/contracts": "workspace:*",
    "@giulio-leone/schemas": "workspace:*",
    "@giulio-leone/types": "workspace:*"
  },
  "sideEffects": false
}

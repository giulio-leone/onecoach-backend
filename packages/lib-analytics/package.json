{
  "name": "@giulio-leone/lib-analytics",
  "version": "0.1.0",
  "description": "Servizi per il dominio analytics",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./analytics.service": {
      "types": "./dist/analytics.service.d.ts",
      "import": "./dist/analytics.service.js",
      "require": "./dist/analytics.service.cjs"
    },
    "./body-measurements.service": {
      "types": "./dist/body-measurements.service.d.ts",
      "import": "./dist/body-measurements.service.js",
      "require": "./dist/body-measurements.service.cjs"
    },
    "./coach-analytics.service": {
      "types": "./dist/coach-analytics.service.d.ts",
      "import": "./dist/coach-analytics.service.js",
      "require": "./dist/coach-analytics.service.cjs"
    },
    "./progress-snapshot.service": {
      "types": "./dist/progress-snapshot.service.d.ts",
      "import": "./dist/progress-snapshot.service.js",
      "require": "./dist/progress-snapshot.service.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "dependencies": {
    "@giulio-leone/lib-ai": "^0.1.0",
    "@giulio-leone/lib-core": "^0.1.0",
    "@giulio-leone/lib-import-core": "^0.1.0",
    "@giulio-leone/lib-shared": "^0.1.0",
    "@giulio-leone/one-workout": "^0.1.0",
    "@giulio-leone/schemas": "^0.1.0",
    "@giulio-leone/contracts": "^0.1.0"
  },
  "peerDependencies": {
    "@giulio-leone/types": "^0.2.0",
    "@prisma/client": "^7.2.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "sideEffects": false
}

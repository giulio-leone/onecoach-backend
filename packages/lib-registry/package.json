{
  "name": "@giulio-leone/lib-registry",
  "version": "0.6.0",
  "description": "Service registry per dependency injection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./register-services": {
      "types": "./dist/register-services.d.ts",
      "import": "./dist/register-services.mjs",
      "require": "./dist/register-services.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsup"
  },
  "peerDependencies": {
    "@giulio-leone/contracts": "workspace:*",
    "@giulio-leone/one-nutrition": "workspace:*",
    "@giulio-leone/one-workout": "workspace:*",
    "@giulio-leone/lib-exercise": "workspace:*",
    "@giulio-leone/lib-food": "workspace:*",
    "@giulio-leone/lib-analytics": "workspace:*",
    "@giulio-leone/lib-core": "workspace:*",
    "@giulio-leone/lib-ai": "workspace:*",
    "@giulio-leone/lib-marketplace": "workspace:*",
    "@giulio-leone/lib-coach": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "sideEffects": false,
  "private": true
}
